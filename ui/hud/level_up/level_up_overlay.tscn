[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://ui/hud/level_up/level_up_overlay.gd" id="1"]

[node name="LevelUpOverlay" type="PanelContainer"]
anchor_left = 0.5
anchor_right = 0.5
anchor_top = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -90.0
offset_right = 200.0
offset_bottom = 90.0
grow_horizontal = 2
grow_vertical = 2
visible = false
script = ExtResource("1")

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 2

[node name="TitleLabel" type="Label" parent="VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "Level Up! Choose a skill:"
horizontal_alignment = 1

[node name="Option1" type="Button" parent="VBox"]
layout_mode = 2
text = "Option 1"

[node name="Option2" type="Button" parent="VBox"]
layout_mode = 2
text = "Option 2"

[connection signal="pressed" from="VBox/Option1" to="." method="_on_option_1_pressed"]
[connection signal="pressed" from="VBox/Option2" to="." method="_on_option_2_pressed"]
