; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Dungeon Adventure 3D"
config/version="0.16.0"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

NetworkMode="*res://bootstrap/network_mode.gd"
GameDatabase="*res://database/game_database.gd"
NetworkManager="*res://net/network_manager.gd"
Bootstrap="*res://bootstrap/bootstrap.gd"
AudioManager="*res://systems/audio_manager.gd"

