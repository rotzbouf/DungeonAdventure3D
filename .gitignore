# Godot 4 editor/import artifacts
.godot/
.import/

# Portable engine + DCC tooling (downloaded, not source — see .tools/README if added)
.tools/

# Raw source art (zips/.blend files) — exported game-ready assets live in
# entities/, assets/, audio/ and are tracked normally
MyAssets/

# Export build outputs (CI uploads these as artifacts)
builds/**/*.x86_64
builds/**/*.exe
builds/**/*.pck

# OS cruft
.DS_Store
Thumbs.db
